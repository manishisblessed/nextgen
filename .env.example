# =====================================================================
# PAYPRISM — environment variables
# Copy to `.env.local` for dev and `.env.production` (or hosting dashboard
# secrets) for prod. NEVER commit real secrets.
# =====================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="Payprism"
NEXT_PUBLIC_APP_URL="https://app.payprismindia.com"
NODE_ENV="development"

# ---------- Auth (NextAuth / JWT) ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET=""

# ---------- Neon Postgres ----------
# Get from https://console.neon.tech → your project → Connection Details
# 1) Pooled URL — used by the app at runtime (serverless friendly)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/payprism?sslmode=require"
# 2) Direct (un-pooled) URL — used ONLY by Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/payprism?sslmode=require"

# ---------- Cloudinary ----------
# Get from https://console.cloudinary.com/console/c-XXXX/settings/api-keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Optional pre-created upload preset for unsigned client uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# ---------- SMS / OTP (pick one) ----------
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="PRISMP"
# OR Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# ---------- Email (Resend / SendGrid / SES) ----------
RESEND_API_KEY=""
EMAIL_FROM="no-reply@payprismindia.com"

# ---------- Payment / Banking partners (replace with whoever you sign up with) ----------
# AePS / DMT / BBPS aggregator (e.g. Eko, PaySprint, IServeU, Spice Money)
PAYSPRINT_PARTNER_ID=""
PAYSPRINT_API_KEY=""
PAYSPRINT_API_SECRET=""
PAYSPRINT_BASE_URL="https://api.paysprint.in/api/v1"

# Payment gateway (Razorpay / Cashfree)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Recharge / DTH (e.g. Plan API / Recharge API India)
RECHARGE_API_TOKEN=""
RECHARGE_API_BASE=""

# Travel (Tripjack / TravelBoutiqueOnline / EaseMyTrip distributor)
TRIPJACK_USER_ID=""
TRIPJACK_PASSWORD=""

# ---------- Push notifications ----------
EXPO_ACCESS_TOKEN=""

# ---------- Observability ----------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ---------- Encryption (PII at rest) ----------
# 32-byte key, base64 — openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# ---------- Rate limiting (Upstash Redis) ----------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
