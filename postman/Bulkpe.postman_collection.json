        {
          "name": "Account Statement",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"page\": 1,\r\n    \"limit\": 50,\r\n\r\n    //below all parameters are optional, can be used for better querying.\r\n    \"fromDate\": \"2024-03-01\", //to filter by date: YYYY-MM-DD\r\n    \"toDate\": \"2024-03-29\", //to filter by date: YYYY-MM-DD\r\n    \"type\": \"DEBIT\", // DEBIT, CREDIT\r\n    \"paymentMode\": \"IMPS\", // IMPS, NEFT, RTGS, UPI\r\n    \"status\": \"SUCCESS\" // SUCCESS, PENDING, FAILED\r\n    \r\n    // \"vaId\": \"\", //optional param to filer by sub virtual accounts\r\n    // \"connectedAccountNumber\": \"502002821068\" //filter param for connected banking accounts\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://api.bulkpe.in/client/accountStatement",
              "protocol": "https",
              "host": [
                "api",
                "bulkpe",
                "in"
              ],
              "path": [
                "client",
                "accountStatement"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Initiate Payout",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"amount\": 1,\r\n    \"account_number\": \"77220101845051\", //beneficiary\r\n    \"payment_mode\": \"UPI\", //IMPS, RTGS, UPI, NEFT are allowed\r\n    \"reference_id\": \"Payout-test6\", //unique id\r\n    \"transcation_note\": \"Refund03\", //optional\r\n    \"beneficiaryName\": \"Your Beneficiary Name\",\r\n    \"ifsc\": \"FDRL0007777\",\r\n    \"upi\": \"dummyUPI@yesbank\" //conditional - only for UPI\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://api.bulkpe.in/client/initiatePayout",
              "protocol": "https",
              "host": [
                "api",
                "bulkpe",
                "in"
              ],
              "path": [
                "client",
                "initiatePayout"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Use Bulkpe Payouts APIs to make payouts from your Virtual Account to any Bank Account or UPI VPA.\n\nOnce a payout is initiated and Bulkpe system and bank process it. You will receive a callback from the Bulkpe system ([setup callback](https://docs.bulkpe.in/debit-webhooks)) with the status of the Payout. You can also call the [Fetch Transaction Status](https://docs.bulkpe.in/fetch-transaction-status) API to get the payout status.\n\nRefer to our [API](https://docs.bulkpe.in/bulkpe-payouts) Docs."
    },
