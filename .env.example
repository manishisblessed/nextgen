# =====================================================================
# NEXTGENPAY — environment variables
# Copy to `.env.local` for dev and `.env.production` (or hosting dashboard
# secrets) for prod. NEVER commit real secrets.
# =====================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="NextGenPay"
# IMPORTANT: Set this to your production domain in deployment (e.g. AWS Amplify / Vercel).
# All invite links, login redirects, and email links use this URL.
NEXT_PUBLIC_APP_URL="https://app.jmpnextgenpay.com"
NODE_ENV="development"

# ---------- Auth (NextAuth / JWT) ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# IMPORTANT: Must match your production domain for OAuth callbacks & redirects.
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET=""

# ---------- Supabase Postgres ----------
# Get from https://supabase.com/dashboard → your project → Settings → Database
# 1) Transaction pooler URL — used by the app at runtime (port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 2) Session pooler URL — used ONLY by Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------- Cloudinary ----------
# Get from https://console.cloudinary.com/console/c-XXXX/settings/api-keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Optional pre-created upload preset for unsigned client uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# ---------- Partner feature flags ----------
# Set to "true" to activate each partner (falls back to MOCK if false or keys missing)
PARTNER_AEPS_ENABLED="false"
PARTNER_DMT_ENABLED="false"
PARTNER_UPI_ENABLED="false"
PARTNER_PAYOUT_ENABLED="false"
PARTNER_BBPS_ENABLED="false"
PARTNER_RECHARGE_ENABLED="false"
PARTNER_TRAVEL_ENABLED="false"
PARTNER_PAN_ENABLED="false"
PARTNER_SMS_ENABLED="false"
PARTNER_EMAIL_ENABLED="false"

# ---------- SMS / OTP — MSG91 (DLT-compliant for India) ----------
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="PRISMP"

# ---------- OTP Provider ----------
# Set to "twilio" to use Twilio Verify for OTPs (no DLT needed).
# Leave unset or "msg91" to use MSG91 (requires DLT registration).
PARTNER_OTP_PROVIDER="twilio"

# ---------- Twilio Verify (managed OTP service) ----------
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Create a Verify Service at https://console.twilio.com/verify/services
TWILIO_VERIFY_SERVICE_SID=""
# Optional: for transactional (non-OTP) SMS via Twilio Programmable Messaging
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_FROM_NUMBER=""

# ---------- Email — Resend ----------
RESEND_API_KEY=""
EMAIL_FROM="noreply@nxtgpay.com"
EMAIL_FROM_INFO="info@nxtgpay.com"

# ---------- AePS / DMT — PaySprint ----------
PAYSPRINT_PARTNER_ID=""
PAYSPRINT_API_KEY=""
PAYSPRINT_JWT_KEY=""
PAYSPRINT_AES_KEY=""
PAYSPRINT_AES_IV=""
PAYSPRINT_BASE_URL="https://api.paysprint.in/api/v1"

# ---------- UPI Collect — Razorpay PG ----------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ---------- Payouts — RazorpayX (legacy fallback) ----------
RAZORPAYX_ACCOUNT_NUMBER=""
RAZORPAYX_KEY_ID=""
RAZORPAYX_KEY_SECRET=""

# ---------- Payouts — BulkPe (primary) ----------
# Activate with PARTNER_PAYOUT_ENABLED="true".
# IMPORTANT: BulkPe IP-whitelists callers — the EC2 box MUST egress from a
# static Elastic IP that you register in the BulkPe dashboard. See docs/PAYOUT.md.
BULKPE_BASE_URL="https://api.bulkpe.in/client"
BULKPE_TOKEN=""
BULKPE_WEBHOOK_SECRET=""

# ---------- Recharge / DTH (future) ----------
RECHARGE_API_TOKEN=""
RECHARGE_API_BASE=""

# ---------- Travel (future — Tripjack / TBO) ----------
TRIPJACK_USER_ID=""
TRIPJACK_PASSWORD=""

# ---------- Push notifications ----------
EXPO_ACCESS_TOKEN=""

# ---------- Observability ----------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ---------- Encryption (PII at rest) ----------
# 32-byte key, base64 — openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# ---------- eKYC Hub (Verification APIs) ----------
# Get from https://connect.ekychub.in/api_token
EKYCHUB_USERNAME=""
EKYCHUB_API_TOKEN=""
EKYCHUB_BASE_URL="https://connect.ekychub.in/v3"
PARTNER_VERIFICATION_ENABLED="false"

# ---------- Monthly Re-KYC gate (Phase 13) ----------
# Network users (RT/DT/MD/SD) must re-verify identity on the 1st of each month
# before transacting (staff/admin are exempt). The scheduler runs in the worker
# at "0 0 1 * *" in Asia/Kolkata (IST). Method options:
#   aadhaar_otp        — Aadhaar OTP eKYC only (default)
#   face_match         — liveness face match only
#   aadhaar_otp+face   — Aadhaar OTP AND a fresh liveness face match
REKYC_METHOD="aadhaar_otp"
# Minimum face-match confidence (0..100) to accept a monthly re-KYC.
REKYC_FACE_MATCH_THRESHOLD="80"
# Optional eKYC Hub endpoint path overrides (align with the live API contract).
EKYCHUB_AADHAAR_OTP_INIT_PATH="/aadhaar/otp"
EKYCHUB_AADHAAR_OTP_VERIFY_PATH="/aadhaar/verify_otp"
EKYCHUB_FACE_MATCH_PATH="/face/match"

# ---------- POS — Same Day Solution Partner API ----------
# Get from Same Day Solution admin panel
SAMEDAY_POS_BASE_URL="https://api.samedaysolution.in"
SAMEDAY_POS_API_KEY=""
SAMEDAY_POS_API_SECRET=""
PARTNER_POS_ENABLED="false"

# ---------- Phase 14: Onboarding liveness video (private S3 + face baseline) ----------
# The 10-second liveness video for network users (RT/DT/MD/SD) is uploaded
# directly from the browser to a PRIVATE S3 bucket via a short-TTL presigned PUT
# URL. Bucket MUST have: Block Public Access ON, SSE-KMS, versioning ON, and a
# TLS-only bucket policy. We store only an encrypted S3 key + sha256 in Postgres.
# In PRODUCTION prefer the EC2 IAM instance role (no static keys); the
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY below are a LOCAL/DEV fallback only.
AWS_REGION="ap-south-1"
S3_KYC_BUCKET="nextgen-kyc-videos"
S3_KMS_KEY_ID="arn:aws:kms:ap-south-1:ACCOUNT_ID:key/KEY_ID"
# Local/dev only — leave EMPTY in production (the IAM role supplies credentials):
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Upload constraints (defaults: 15 MiB, 12 seconds).
KYC_VIDEO_MAX_BYTES="15728640"
KYC_VIDEO_MAX_DURATION_SEC="12"
# ffmpeg / ffprobe binaries on EC2 (apt install ffmpeg) — used by the worker to
# extract one clear face frame for the eKYC Hub baseline.
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
# eKYC Hub face-baseline registration endpoint (aligns with the live contract).
EKYCHUB_FACE_REGISTER_PATH="/face/register"

# ---------- Rate limiting (Upstash Redis) ----------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =====================================================================
# Security controls (see SECURITY.md)
# In PRODUCTION these (and all secrets above) are loaded from AWS SSM /
# Secrets Manager by deploy/load-secrets.sh — NOT from a committed file.
# =====================================================================

# ---------- CAPTCHA — Cloudflare Turnstile ----------
# When "true", login/register/OTP require a valid Turnstile token and the
# secret key MUST be set (endpoints fail closed otherwise).
SECURITY_CAPTCHA_ENABLED="false"
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ---------- Breached-password check (Have I Been Pwned, k-anonymity) ----------
# Default on; set "false" to disable (e.g. air-gapped environments).
SECURITY_HIBP_ENABLED="true"

# ---------- Step-up 2FA on sensitive actions ----------
# Requires a fresh TOTP/backup code for payout approval, scheme changes and
# withdrawals. Roll out the client step-up prompt before enabling in prod.
SECURITY_STEPUP_ENABLED="false"

# ---------- Request size limit (bytes) ----------
SECURITY_MAX_BODY_BYTES="1048576"

# ---------- Trusted reverse-proxy hops ----------
# Number of trusted proxy hops in front of the app (EC2 → nginx = 1). Used to
# resolve the real client IP from X-Forwarded-For WITHOUT trusting the
# client-controlled left-most value. Set to 2 if a CDN (e.g. Cloudflare) is
# placed in front of nginx.
TRUSTED_PROXY_HOPS="1"

# ---------- Logging ----------
LOG_LEVEL="info"
