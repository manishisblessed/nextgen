{
  "expo": {
    "name": "NextGenPay Retailer",
    "slug": "nextgenpay-retailer",
    "scheme": "nextgenpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jmpnextgenpay.retailer",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to your NextGenPay account."
      }
    },
    "android": {
      "package": "com.jmpnextgenpay.retailer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "permissions": ["USE_FINGERPRINT", "USE_BIOMETRIC"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to sign in to your NextGenPay account."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
