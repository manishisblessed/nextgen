# =====================================================================
# NEXTGENPAY — environment variables
# Copy to `.env.local` for dev and `.env.production` (or hosting dashboard
# secrets) for prod. NEVER commit real secrets.
# =====================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="NextGenPay"
NEXT_PUBLIC_APP_URL="https://app.jmpnextgenpay.com"
NODE_ENV="development"

# ---------- Auth (NextAuth / JWT) ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET=""

# ---------- Supabase Postgres ----------
# Get from https://supabase.com/dashboard → your project → Settings → Database
# 1) Transaction pooler URL — used by the app at runtime (port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 2) Session pooler URL — used ONLY by Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------- Cloudinary ----------
# Get from https://console.cloudinary.com/console/c-XXXX/settings/api-keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Optional pre-created upload preset for unsigned client uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# ---------- Partner feature flags ----------
# Set to "true" to activate each partner (falls back to MOCK if false or keys missing)
PARTNER_AEPS_ENABLED="false"
PARTNER_DMT_ENABLED="false"
PARTNER_UPI_ENABLED="false"
PARTNER_PAYOUT_ENABLED="false"
PARTNER_BBPS_ENABLED="false"
PARTNER_RECHARGE_ENABLED="false"
PARTNER_TRAVEL_ENABLED="false"
PARTNER_PAN_ENABLED="false"
PARTNER_SMS_ENABLED="false"
PARTNER_EMAIL_ENABLED="false"

# ---------- SMS / OTP — MSG91 (DLT-compliant for India) ----------
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="PRISMP"

# ---------- Email — Resend ----------
RESEND_API_KEY=""
EMAIL_FROM="no-reply@jmpnextgenpay.com"

# ---------- AePS / DMT — PaySprint ----------
PAYSPRINT_PARTNER_ID=""
PAYSPRINT_API_KEY=""
PAYSPRINT_JWT_KEY=""
PAYSPRINT_AES_KEY=""
PAYSPRINT_AES_IV=""
PAYSPRINT_BASE_URL="https://api.paysprint.in/api/v1"

# ---------- UPI Collect — Razorpay PG ----------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ---------- Payouts — RazorpayX ----------
RAZORPAYX_ACCOUNT_NUMBER=""
RAZORPAYX_KEY_ID=""
RAZORPAYX_KEY_SECRET=""

# ---------- Recharge / DTH (future) ----------
RECHARGE_API_TOKEN=""
RECHARGE_API_BASE=""

# ---------- Travel (future — Tripjack / TBO) ----------
TRIPJACK_USER_ID=""
TRIPJACK_PASSWORD=""

# ---------- Push notifications ----------
EXPO_ACCESS_TOKEN=""

# ---------- Observability ----------
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ---------- Encryption (PII at rest) ----------
# 32-byte key, base64 — openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# ---------- eKYC Hub (Verification APIs) ----------
# Get from https://connect.ekychub.in/api_token
EKYCHUB_USERNAME=""
EKYCHUB_API_TOKEN=""
EKYCHUB_BASE_URL="https://connect.ekychub.in/v3"
PARTNER_VERIFICATION_ENABLED="false"

# ---------- Rate limiting (Upstash Redis) ----------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
