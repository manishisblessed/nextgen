// =====================================================================
// JMP NextGenPay — production schema (Supabase Postgres + Prisma)
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth & RBAC ----------

enum Role {
  RETAILER
  DISTRIBUTOR
  MASTER_DISTRIBUTOR
  SUPER_DISTRIBUTOR
  ADMIN
  SUPPORT
  FINANCE
  MASTER_ADMIN
}

enum UserStatus {
  PENDING_KYC
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id                   String     @id @default(cuid())
  name                 String
  email                String     @unique
  phone                String     @unique
  passwordHash         String
  role                 Role       @default(RETAILER)
  status               UserStatus @default(PENDING_KYC)
  emailVerifiedAt      DateTime?
  phoneVerifiedAt      DateTime?
  twoFactorEnabled     Boolean    @default(false)
  twoFactorSecret      String? // AES-256 encrypted TOTP secret
  twoFactorBackupCodes String[]   @default([]) // bcrypt-hashed single-use recovery codes
  twoFactorVerifiedAt  DateTime? // when 2FA was first confirmed

  // Server-side session invalidation. Every issued JWT carries the tokenVersion
  // it was minted with; the jwt/session callbacks reject any token whose version
  // != this value. Incrementing it (logout, role/status change, forced sign-out)
  // instantly invalidates all outstanding sessions for this user — defends
  // against replay of a cached/stolen session cookie.
  tokenVersion Int @default(0)

  // tabs/features assigned by a higher-level admin (empty = full access for that role)
  allowedTabs String[] @default([])

  // Service-level access control (allowlist). Stores ServiceRoute keys that an
  // admin has explicitly enabled for this user. Empty = NO services available
  // (default-disabled). Staff roles (SUPPORT/ADMIN/MASTER_ADMIN) bypass this.
  // Checked by assertServiceEnabled() before any money rail call.
  enabledServices String[] @default([])

  // ── Monthly Re-KYC gate (Phase 13) ──────────────────────────────────────
  // Network tiers (RT/DT/MD/SD) must re-verify identity on the 1st of every
  // month before they can transact. A scheduled job raises `reKycRequired` for
  // ACTIVE network users; a successful re-KYC clears it and pushes `reKycDueAt`
  // to the 1st of the next month. Staff/admin roles are never gated.
  reKycRequired Boolean   @default(false)
  lastReKycAt   DateTime?
  reKycDueAt    DateTime?

  // ── Onboarding liveness video / face baseline (Phase 14) ────────────────
  // Network tiers (RT/DT/MD/SD) must record a short liveness video at onboarding;
  // a face frame from it becomes the baseline for Phase 13's monthly face match.
  // Until the baseline is ready, transactions are blocked (login/read stay open).
  // Staff/admin roles are never prompted and never gated. The video bytes live in
  // a private S3 bucket — only an encrypted key + hash is kept (see KycVideo).
  hasLivenessVideo Boolean @default(false)

  // ── Transaction PIN ──────────────────────────────────────────────────────
  // A 4–6 digit PIN (bcrypt-hashed) verified at the moment of EVERY
  // money-moving action (bill pay, recharge, DMT, AePS, payout). Distinct from
  // the login password and 2FA: cheap to enter per-transaction, blunts a
  // walk-up/hijacked-session attack. 5 wrong attempts → 15 min lockout.
  txnPinHash           String?
  txnPinSetAt          DateTime?
  txnPinFailedAttempts Int       @default(0)
  txnPinLockedUntil    DateTime?

  // Commission/charge scheme assigned to this user. Null = fall back to the
  // platform default scheme (Scheme.isDefault). Resolved by getEffectiveRate.
  schemeId String?
  scheme   Scheme? @relation("UserScheme", fields: [schemeId], references: [id])

  // hierarchy
  parentId String?
  parent   User?   @relation("Hierarchy", fields: [parentId], references: [id])
  children User[]  @relation("Hierarchy")

  // org / shop info
  shopName    String?   @unique
  shopAddress String?
  pincode     String?
  state       String?
  city        String?

  // financial summary (denormalized for fast reads; keep authoritative ledger in WalletTxn)
  // walletBalance = available/spendable balance. heldBalance = funds reserved for
  // in-flight operations (e.g. a pending payout). spendable = walletBalance - heldBalance.
  walletBalance Decimal @default(0) @db.Decimal(14, 2)
  heldBalance   Decimal @default(0) @db.Decimal(14, 2)
  // Secondary AEPS wallet — AEPS/Aadhaar-Pay proceeds settle here first and move
  // to the primary wallet (or a bank account) via an explicit settlement. Kept as
  // its own column so the ledger can maintain independent balanceAfter chains
  // per wallet (WalletTxn.walletType discriminates the two books).
  aepsBalance   Decimal @default(0) @db.Decimal(14, 2)

  // login location tracking
  lastLoginLat Float?
  lastLoginLng Float?
  lastLoginAt  DateTime?

  // device / session-context tracking for anomaly detection (new-device, impossible travel)
  lastLoginIp        String?
  lastLoginUserAgent String?
  knownDevices       String[] @default([]) // sha256 hashes of trusted device/user-agent fingerprints

  kyc                  Kyc?
  documents            Document[]
  wallet               WalletTxn[]
  transactions         Transaction[]
  fundRequestsRaised   FundRequest[]    @relation("FundRequester")
  fundRequestsApproved FundRequest[]    @relation("FundApprover")
  apiKeys              ApiKey[]
  sessions             Session[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  commissionSlabs      CommissionSlab[]
  payoutRequests       PayoutRequest[]  @relation("PayoutOwner")
  schemesCreated       Scheme[]         @relation("SchemeCreator")
  posMachines          PosMachine[]     @relation("PosAssignee")
  slidersCreated       Slider[]         @relation("SliderCreator")
  reKycLogs            ReKycLog[]
  kycVideo             KycVideo?
  declarationsToApprove DeclarationApproval[] @relation("DeclarationApprover")
  declarationsRequested DeclarationApproval[] @relation("DeclarationRequester")
  disputes              Dispute[]             @relation("DisputeOwner")
  disputesResolved      Dispute[]             @relation("DisputeResolver")
  disputeMessages       DisputeMessage[]      @relation("DisputeMessageAuthor")
  webhookEndpoints      WebhookEndpoint[]     @relation("WebhookOwner")
  whitelabelProfile     WhitelabelProfile?    @relation("WhitelabelOwner")
  amlAlerts             AmlAlert[]            @relation("AmlAlertUser")
  amlReviews            AmlAlert[]            @relation("AmlAlertReviewer")
  staticQrsCreated      StaticQr[]            @relation("StaticQrCreator")
  qrClaims              QrClaim[]             @relation("QrClaimOwner")
  qrClaimsReviewed      QrClaim[]             @relation("QrClaimReviewer")
  walletOpsPerformed    WalletOperation[]     @relation("WalletOpActor")
  walletOpsReceived     WalletOperation[]     @relation("WalletOpTarget")
  walletOpsApproved     WalletOperation[]     @relation("WalletOpApprover")
  mdrScheme             MdrScheme?            @relation("UserMdrScheme", fields: [mdrSchemeId], references: [id])
  userLimit             UserLimit?
  reversalsCreated      Reversal[]            @relation("ReversalActor")
  reversalsReceived     Reversal[]            @relation("ReversalTarget")
  settlementConfig      UserSettlementConfig?
  posSubscriptions      PosSubscription[]     @relation("PosSubscriber")
  posRentalPlansOwned   PosRentalPlan[]       @relation("PosRentalPlanOwner")
  aepsMerchant          AepsMerchant?
  aepsSettlementAccounts AepsSettlementAccount[] @relation("AepsAccountOwner")
  aepsSettlements       AepsSettlement[]      @relation("AepsSettlementOwner")
  commissionCredits     CommissionCredit[]    @relation("CommissionCredits")
  posSettlements        PosSettlementEntry[]  @relation("PosSettlements")
  networkTransfersOut   NetworkWalletTransfer[] @relation("NetworkTransfersOut")
  networkTransfersIn    NetworkWalletTransfer[] @relation("NetworkTransfersIn")

  // MDR scheme assignment (Phase 3) — resolved by the MDR engine alongside
  // the charge/commission Scheme. Null = platform default MDR scheme.
  mdrSchemeId String?

  // POS acquirer settlement mode (admin-toggleable only).
  // true = proceeds credit instantly on webhook; false = T+1 cron.
  instantSettlement Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([role])
  @@index([parentId])
  @@index([status])
  @@index([schemeId])
  @@index([mdrSchemeId])
  @@index([reKycRequired])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String    @unique
  device       String?
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

// ---------- Brute-force protection ----------
// Per-identifier failed-login tracking that drives account lockout with
// exponential backoff. Keyed by the normalized identifier (email/phone) so it
// works even when the identifier does not resolve to a real user (this avoids
// account-enumeration via timing while still throttling guessing). The dedicated
// /api/auth/login route and the NextAuth credentials provider both consult this.
model LoginAttempt {
  id           String    @id @default(cuid())
  identifier   String    @unique // normalized email/phone (lowercased + trimmed)
  failedCount  Int       @default(0)
  lockedUntil  DateTime? // when set & in the future, auth is refused
  lastFailedAt DateTime?
  lastIp       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([lockedUntil])
}

model Otp {
  id        String   @id @default(cuid())
  channel   String // SMS | EMAIL
  target    String // phone or email
  codeHash  String
  purpose   String // LOGIN | REGISTER | RESET | TXN | ONBOARD
  attempts  Int      @default(0)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([target, purpose])
}

// ---------- KYC & documents ----------

enum KycStatus {
  NOT_STARTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model Kyc {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            KycStatus @default(NOT_STARTED)
  panNumber         String?   @unique
  panVerifiedAt     DateTime?
  panName           String?
  aadhaarLast4      String?
  aadhaarVerifiedAt DateTime?
  aadhaarNumber     String?   @unique
  aadhaarName       String?
  aadhaarDob        String?
  aadhaarGender     String?
  aadhaarAddress    String?
  aadhaarMobile     String? // Aadhaar-registered mobile for records
  bankAccountName   String?
  bankAccountNumber String?   @unique
  bankIfsc          String?
  bankAccountStatus String? // active | inactive
  gstin             String?   @unique
  msmeNumber        String?   @unique
  nameMismatch      Boolean   @default(false)
  dob               DateTime?
  rejectedReason    String?
  reviewedById      String?
  reviewedAt        DateTime?
  submittedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ---------- Monthly Re-KYC audit trail (Phase 13) ----------
// One row per re-verification attempt by a network user. Holds NO raw PII —
// only the method, provider correlation reference, outcome, and request
// context. PII returned by the eKYC Hub is field-encrypted/masked before it is
// ever persisted (see src/lib/rekyc/*).

enum ReKycStatus {
  PENDING
  PASSED
  FAILED
}

model ReKycLog {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  method      String // aadhaar_otp | face_match | aadhaar_otp+face
  status      ReKycStatus @default(PENDING)
  provider    String? // EKYCHUB | SIMULATED
  providerRef String? // opaque provider verification id / orderid (never raw Aadhaar)
  ip          String?
  userAgent   String?
  meta        Json? // safe extras (masked values, enrolledBaseline flag, failureCode)
  createdAt   DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ---------- Onboarding liveness video / face baseline (Phase 14) ----------
// One row per network user. The 10-second liveness video is stored in a PRIVATE
// S3 bucket (Block Public Access, SSE-KMS, versioning). We persist NO video
// bytes here — only the field-encrypted S3 object key, a sha256 of the bytes for
// integrity, and the field-encrypted eKYC Hub face-baseline reference. Access to
// the video is admin-only via short-TTL signed URLs and is always audited.
// DPDP/RBI: biometric PII — explicit consent (consentAt) is mandatory and a
// retention policy purges the object + nulls the references after closure.

enum KycVideoStatus {
  UPLOADED // object stored in S3; baseline extraction queued
  BASELINE_READY // a face frame was registered as the baseline
  FAILED // no usable face detected — user must re-capture
}

model KycVideo {
  id                 String         @id @default(cuid())
  userId             String         @unique
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           String         @default("s3")
  storageKeyEnc      String // S3 object key, field-encrypted (fieldEncryption.ts)
  sha256             String // hex digest of the uploaded video bytes (integrity)
  durationSec        Int
  sizeBytes          Int
  contentType        String
  faceBaselineRefEnc String? // eKYC Hub baseline reference, field-encrypted
  status             KycVideoStatus @default(UPLOADED)
  consentAt          DateTime // explicit biometric-capture consent timestamp
  capturedIp         String?
  capturedUa         String?
  // Phase 5 — retention: raw video purged from S3 after the retention window
  // (baseline + metadata retained). Set by the daily retention worker.
  purgedAt           DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status])
}

enum DocumentType {
  PAN
  AADHAAR_FRONT
  AADHAAR_BACK
  SHOP_PHOTO
  BANK_PROOF
  CANCEL_CHEQUE
  PASSBOOK
  GST_CERT
  SELFIE
  LIVE_VIDEO
  AGREEMENT
  SHOP_ESTABLISHMENT
  GUMASTA_LICENSE
  SIGNATURE
  ELECTRICITY_BILL
  ADDITIONAL_ID
  FAMILY_REFERENCE
  PG_FORM
  GPS_PHOTO_OUTSIDE
  GPS_PHOTO_INSIDE
  GPS_SELFIE_DISTRIBUTOR
  DISTRIBUTOR_DECLARATION
  SELF_DECLARATION
  SUCCESSOR_DECLARATION
  OTHER
}

// ---------- Declaration Approval (Successor responsibility chain) ----------
// When a network user onboards a subordinate, the subordinate must upload a
// prefilled self-declaration form AND (except for SD created by Admin) the
// creator (successor) must also approve by signing a responsibility declaration
// with signature, selfie, and GPS-timestamped evidence.

enum DeclarationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model DeclarationApproval {
  id            String            @id @default(cuid())
  inviteId      String
  requestedById String
  requestedBy   User              @relation("DeclarationRequester", fields: [requestedById], references: [id])
  approverId    String
  approver      User              @relation("DeclarationApprover", fields: [approverId], references: [id])
  approverRole  Role
  onboardeeRole Role

  status DeclarationStatus @default(PENDING)

  declarationDocUrl String?

  approverSignatureUrl String?
  approverSelfieUrl    String?
  approvedAt           DateTime?
  approvalIp           String?
  approvalUserAgent    String?
  approvalLatitude     Float?
  approvalLongitude    Float?

  rejectedAt     DateTime?
  rejectedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inviteId])
  @@index([approverId, status])
}

model Document {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         DocumentType
  // Cloudinary
  publicId     String // e.g. "nextgenpay/kyc/abc123"
  url          String // secure_url
  resourceType String       @default("image") // image | raw | video
  format       String?
  bytes        Int?
  width        Int?
  height       Int?
  // GPS metadata for geo-tagged uploads
  gpsLatitude  Float?
  gpsLongitude Float?
  // privacy: signed delivery — never expose publicly
  isSensitive  Boolean      @default(true)
  uploadedAt   DateTime     @default(now())

  @@index([userId, type])
}

// ---------- Wallet ledger (double-entry-style) ----------

enum WalletDirection {
  CREDIT
  DEBIT
}

enum WalletReason {
  TOPUP
  WITHDRAW
  TRANSACTION
  COMMISSION
  REVERSAL
  ADJUSTMENT
  FUND_TRANSFER_IN
  FUND_TRANSFER_OUT
  FEE
  PENALTY
  PAYOUT
  SETTLEMENT
  AEPS_SETTLEMENT
  RENTAL
  POS_SETTLEMENT    // POS acquirer proceeds (instant or T+1)
  PARENT_PUSH       // Network parent crediting child
  PARENT_PULL       // Network parent debiting child
}

/// Which wallet book a ledger entry belongs to. PRIMARY = the main spendable
/// wallet (User.walletBalance); AEPS = the secondary AEPS proceeds wallet
/// (User.aepsBalance). Each book keeps its own balanceAfter chain.
enum WalletType {
  PRIMARY
  AEPS
}

model WalletTxn {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  walletType     WalletType      @default(PRIMARY)
  direction      WalletDirection
  reason         WalletReason
  amount         Decimal         @db.Decimal(14, 2)
  balanceAfter   Decimal         @db.Decimal(14, 2)
  refType        String? // "Transaction" | "FundRequest" | "PayoutRequest" | etc
  refId          String?
  note           String?
  // Idempotency guard — a unique key ensures a given money movement is applied
  // at most once, even under retries / duplicate webhook deliveries.
  idempotencyKey String?         @unique
  createdAt      DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([refType, refId])
  @@index([walletType, createdAt])
  @@index([reason, createdAt])
}

// ---------- Transactions ----------

enum ServiceCode {
  AEPS_BALANCE
  AEPS_WITHDRAW
  AEPS_MINI_STMT
  DMT_IMPS
  DMT_NEFT
  DMT_RTGS
  UPI_COLLECT
  UPI_PAYOUT
  WALLET_TOPUP
  WALLET_WITHDRAW
  RECHARGE_MOBILE
  RECHARGE_DTH
  RECHARGE_BROADBAND
  BILL_ELECTRICITY
  BILL_WATER
  BILL_GAS
  BILL_CREDIT_CARD
  BILL_EDUCATION
  BILL_INSURANCE
  TRAVEL_FLIGHT
  TRAVEL_HOTEL
  TRAVEL_BUS
  TRAVEL_TRAIN
  PAN_CARD
  INSURANCE
}

enum TxnStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  HOLD
}

model Transaction {
  id           String      @id @default(cuid())
  refId        String      @unique // human-friendly: TXN8K2X9P
  userId       String // retailer who originated it
  user         User        @relation(fields: [userId], references: [id])
  service      ServiceCode
  amount       Decimal     @db.Decimal(14, 2)
  fee          Decimal     @default(0) @db.Decimal(14, 2)
  commission   Decimal     @default(0) @db.Decimal(14, 2)
  gst          Decimal     @default(0) @db.Decimal(14, 2)
  status       TxnStatus   @default(INITIATED)
  customer     String? // mobile / consumerNo / VPA / a/c last 4
  operator     String? // SBI, Jio, BSES, etc.
  // partner details
  partner      String? // PAYSPRINT, RAZORPAY, etc.
  partnerTxnId String?
  // arbitrary partner payload for audit / reconciliation
  request      Json?
  response     Json?
  errorCode    String?
  errorMessage String?
  // refunds
  refundedAt   DateTime?
  refundRefId  String?

  ipAddress String?
  device    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissionCredits CommissionCredit[]

  @@index([userId, createdAt])
  @@index([service, status])
  @@index([status, createdAt])
}

// ---------- Commissions ----------

model CommissionSlab {
  id            String      @id @default(cuid())
  userId        String // applies to this user / level
  user          User        @relation(fields: [userId], references: [id])
  service       ServiceCode
  minAmount     Decimal     @db.Decimal(14, 2)
  maxAmount     Decimal     @db.Decimal(14, 2)
  // either flat or percent — but enforce one in app code
  flat          Decimal?    @db.Decimal(14, 2)
  percent       Decimal?    @db.Decimal(6, 4) // e.g. 0.0050 for 0.5%
  active        Boolean     @default(true)
  effectiveFrom DateTime    @default(now())
  effectiveTo   DateTime?

  @@index([userId, service, active])
}

// ---------- Scheme Manager (named groupings of charge/commission slabs) ----------
// A Scheme bundles per-service charge + commission slabs and is assigned to
// users (User.schemeId). Assignment cascades down the network: admin assigns a
// platform scheme to super-distributors; each parent derives their own scheme
// (ownerId/parentSchemeId) with per-slab markup and assigns it to children.
// Users with NO active scheme are blocked from financial transactions (see
// src/lib/scheme/gate.ts). The resolver (src/lib/scheme/resolver.ts) reads
// these; isDefault is retained for admin bookkeeping but is no longer a
// runtime pricing fallback.

/// Whether a slab value is a flat rupee amount or a percentage fraction
/// (e.g. 0.0050 = 0.5%). Mirrors the CommissionSlab flat/percent convention.
enum RateType {
  FLAT
  PERCENT
}

model Scheme {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  active      Boolean      @default(true)
  isDefault   Boolean      @default(false)
  createdById String?
  createdBy   User?        @relation("SchemeCreator", fields: [createdById], references: [id])

  // Hierarchical derivation: a network parent (SD/MD/DT) derives their own
  // scheme from the one assigned to them, adding margin per slab. ownerId is
  // the deriving user (null = platform/admin scheme); parentSchemeId points at
  // the scheme it was derived from. Derived slabs keep the parent's bands and
  // rate types; only values change (charge >= parent, commission <= parent).
  ownerId        String?
  parentSchemeId String?
  parentScheme   Scheme?  @relation("SchemeDerivation", fields: [parentSchemeId], references: [id])
  derivedSchemes Scheme[] @relation("SchemeDerivation")

  slabs       SchemeSlab[]
  users       User[]       @relation("UserScheme")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([active])
  @@index([isDefault])
  @@index([ownerId])
  @@index([parentSchemeId])
}

model SchemeSlab {
  id        String      @id @default(cuid())
  schemeId  String
  scheme    Scheme      @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  service   ServiceCode
  // Provider dimension: when a service is routed through multiple partners
  // (e.g. BBPS 1 vs BBPS 2), a slab may target one provider specifically.
  // null = applies to any provider. Resolution prefers an exact provider
  // match over the null wildcard for the same band.
  provider  String?
  minAmount Decimal     @db.Decimal(14, 2)
  maxAmount Decimal     @db.Decimal(14, 2)

  // Customer-facing charge for this slab. `chargeValue` is a flat ₹ amount when
  // chargeType = FLAT, or a fraction (0.0050 = 0.5%) when chargeType = PERCENT.
  chargeType  RateType @default(FLAT)
  chargeValue Decimal  @default(0) @db.Decimal(14, 4)

  // Commission split across the distribution chain. Same flat/percent semantics
  // as the charge (driven by commissionType). All three may be zero.
  commissionType             RateType @default(PERCENT)
  commissionRetailer         Decimal  @default(0) @db.Decimal(14, 4)
  commissionDistributor      Decimal  @default(0) @db.Decimal(14, 4)
  commissionMaster           Decimal  @default(0) @db.Decimal(14, 4)
  commissionSuperDistributor Decimal  @default(0) @db.Decimal(14, 4)

  // Cascade model: commission earned by the user THIS scheme is assigned to
  // (single value; per-tier margins are derived from scheme-chain differences,
  // not from the legacy per-tier columns above). Same RateType semantics as
  // commissionType. parentSlabId links a derived slab back to the slab it was
  // copied from, so markup validation never depends on band matching.
  commissionValue Decimal @default(0) @db.Decimal(14, 4)
  parentSlabId    String?

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schemeId, service, active])
  @@index([parentSlabId])
}

// ---------- Fund requests ----------

enum FundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model FundRequest {
  id          String            @id @default(cuid())
  requesterId String
  requester   User              @relation("FundRequester", fields: [requesterId], references: [id])
  approverId  String?
  approver    User?             @relation("FundApprover", fields: [approverId], references: [id])
  amount      Decimal           @db.Decimal(14, 2)
  mode        String // UTR | UPI | CASH
  utr         String?
  bankName    String?
  proofDocId  String? // Document.id
  status      FundRequestStatus @default(PENDING)
  remarks     String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime          @default(now())

  @@index([requesterId, status])
  @@index([approverId, status])
}

// ---------- API keys (for white-label master distributors) ----------

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  keyId       String    @unique // public id
  secretHash  String
  scopes      String[] // ["txn.read","txn.create","wallet.topup"]
  ipAllowlist String[]  @default([])
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ---------- Platform play (Phase 4) — outbound webhooks & whitelabel ----------
// WebhookEndpoint: a partner-registered HTTPS URL that receives signed event
// notifications (txn.success, payout.success, topup.credited, …). The signing
// secret is generated by us and stored encrypted; every delivery carries an
// HMAC-SHA256 signature of the raw body.

model WebhookEndpoint {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("WebhookOwner", fields: [userId], references: [id], onDelete: Cascade)

  url    String
  // AES-256-GCM encrypted signing secret (see crypto/fieldEncryption).
  secret String
  events String[] // subset of WEBHOOK_EVENTS (src/lib/platform/webhooks.ts)
  active Boolean  @default(true)

  deliveries WebhookDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WebhookDelivery {
  id         String          @id @default(cuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  event   String
  payload Json
  status  String @default("PENDING") // PENDING | SUCCESS | FAILED

  attempts     Int       @default(0)
  responseCode Int?
  lastError    String?
  deliveredAt  DateTime?

  createdAt DateTime @default(now())

  @@index([endpointId, createdAt])
  @@index([status, createdAt])
}

// WhitelabelProfile: per-MD/SD brand configuration for running the platform
// under their own name. `subdomain`/`customDomain` are the tenancy handles a
// public resolver maps to this profile.
model WhitelabelProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("WhitelabelOwner", fields: [userId], references: [id], onDelete: Cascade)

  brandName    String
  tagline      String?
  logoUrl      String?
  faviconUrl   String?
  primaryColor String  @default("#185df5")
  accentColor  String  @default("#f97606")
  supportEmail String?
  supportPhone String?

  subdomain    String? @unique // e.g. "kapoorpay" → kapoorpay.<platform-domain>
  customDomain String? @unique // e.g. "kapoorpay.in"

  status String @default("DRAFT") // DRAFT | LIVE | SUSPENDED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Compliance maturity (Phase 5) — AML monitoring & audit anchoring ----------
// AmlAlert: post-transaction AML monitoring output. The hourly sweep evaluates
// rule patterns (high value / CTR aggregation / structuring / dormant burst)
// and files one alert per (user, rule, IST day) — the unique key makes the
// sweep idempotent. Compliance reviews the queue and marks alerts CLEARED or
// REPORTED (STR filed with FIU-IND).
model AmlAlert {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("AmlAlertUser", fields: [userId], references: [id], onDelete: Cascade)

  rule     String // HIGH_VALUE | AGG_DAILY_VOLUME | STRUCTURING | DORMANT_BURST
  severity String // HIGH | MEDIUM
  status   String @default("OPEN") // OPEN | UNDER_REVIEW | CLEARED | REPORTED
  dateKey  String // IST date bucket (YYYY-MM-DD) — dedup key for the sweep
  details  Json // rule-specific evidence (amounts, counts, txn refs)

  reviewedById String?
  reviewedBy   User?     @relation("AmlAlertReviewer", fields: [reviewedById], references: [id])
  reviewNote   String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())

  @@unique([userId, rule, dateKey])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

// AuditAnchor: daily hash-chain anchor over AuditLog. Each anchor hashes the
// day's audit rows (canonical order) and chains onto the previous anchor, so
// any retroactive tampering with audit history breaks verification. The table
// itself (and AuditLog) is append-only, enforced by a DB trigger.
model AuditAnchor {
  id         String   @id @default(cuid())
  dateKey    String   @unique // IST day (YYYY-MM-DD) the anchor covers
  rowCount   Int
  firstRowId String?
  lastRowId  String?
  rootHash   String // SHA-256 over the day's canonical row digest stream
  prevHash   String // previous anchor's chainHash ("" for genesis)
  chainHash  String // SHA-256(prevHash + rootHash)
  createdAt  DateTime @default(now())
}

// ---------- Audit / system ----------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // user.login, kyc.approve, txn.refund, ...
  entity    String? // User | Transaction | Kyc
  entityId  String?
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  channel   String // INAPP | EMAIL | SMS | PUSH
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// ---------- Disputes / Support tickets (Phase 3 — agent experience) ----------
// A Dispute is a support ticket raised by a network user (usually about a
// transaction). Every ticket carries an SLA deadline computed from priority;
// a scheduled worker sweep flags breaches and alerts ops. Conversation lives
// in DisputeMessage rows (user ↔ support thread).

enum DisputeCategory {
  TRANSACTION // failed/duplicate/amount-mismatch txns
  SETTLEMENT
  COMMISSION
  WALLET
  KYC
  OTHER
}

enum DisputeStatus {
  OPEN // raised, no support response yet
  UNDER_REVIEW // support engaged
  AWAITING_USER // support asked the user for info; SLA clock paused
  RESOLVED
  REJECTED
}

enum DisputePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Dispute {
  id       String @id @default(cuid())
  ticketNo String @unique // human-friendly: DSP8K2X9P

  userId String
  user   User   @relation("DisputeOwner", fields: [userId], references: [id])

  category    DisputeCategory
  priority    DisputePriority @default(NORMAL)
  status      DisputeStatus   @default(OPEN)
  subject     String
  description String

  // Optional link to the transaction under dispute (Transaction.refId).
  txnRefId String?

  // SLA tracking. slaDueAt is set at creation from priority (and re-based on
  // escalation); the worker sweep stamps slaBreachedAt once, alerts ops, and
  // auto-escalates priority. firstResponseAt = first support reply.
  slaDueAt        DateTime
  slaBreachedAt   DateTime?
  firstResponseAt DateTime?

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("DisputeResolver", fields: [resolvedById], references: [id])
  resolution   String?
  reopenCount  Int       @default(0)

  messages DisputeMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, slaDueAt])
  @@index([status, priority, createdAt])
}

model DisputeMessage {
  id        String  @id @default(cuid())
  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation("DisputeMessageAuthor", fields: [authorId], references: [id])
  // true when the author acted as support/admin (drives thread styling + SLA
  // first-response stamping).
  fromSupport Boolean @default(false)

  body      String
  createdAt DateTime @default(now())

  @@index([disputeId, createdAt])
}

// ---------- Onboarding Invites ----------

enum InviteStatus {
  PENDING
  REGISTERED
  VERIFIED
  APPROVED
  REJECTED
  EXPIRED
}

model Invite {
  id          String       @id @default(cuid())
  token       String       @unique @default(cuid())
  phone       String
  email       String
  role        Role
  parentId    String?
  invitedById String
  status      InviteStatus @default(PENDING)

  userId String? @unique
  name   String?

  expiresAt        DateTime
  registeredAt     DateTime?
  verifiedAt       DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  phoneVerifiedAt  DateTime?
  emailVerifiedAt  DateTime?
  aadhaarVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([invitedById, status])
  @@index([phone])
  @@index([email])
}

// ---------- Verification Results (eKYC Hub) ----------

model VerificationResult {
  id              String   @id @default(cuid())
  userId          String?
  inviteId        String?
  type            String // PAN_360 | BANK_PENNY_DROP | AADHAAR_DIGILOCKER | GST | CIN | BANK_ADVANCE
  orderid         String   @unique
  status          String // Success | Failure
  verifiedName    String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())

  @@index([userId, type])
  @@index([inviteId, type])
}

// ---------- Master data ----------

model Operator {
  id      String      @id @default(cuid())
  service ServiceCode
  name    String
  code    String      @unique
  logoUrl String?
  active  Boolean     @default(true)
  meta    Json?

  @@index([service, active])
}

model Biller {
  id          String  @id @default(cuid())
  category    String // ELECTRICITY | WATER | GAS | INSURANCE | EDUCATION
  name        String
  code        String  @unique
  state       String?
  active      Boolean @default(true)
  partner     String? // BBPS / BillAvenue
  partnerCode String?

  @@index([category, state, active])
}

// =====================================================================
// Phase 0 — Secure foundation
// =====================================================================

// ---------- Service / vendor route registry ----------
// One unified registry of toggleable money rails & platform flags. Powers the
// On/Off Services panel, dashboard "Service Overview" + "Vendor Balances", and
// (later) the Scheme Manager service chips. An OFF route hard-gates its rail.

enum ServiceRouteType {
  SERVICE // a payable money rail (PG, POS, BBPS, Payout, QR, ...)
  CONFIG // a platform configuration flag
  SETTING // a platform setting flag
}

enum ServiceRouteKind {
  PG
  POS
  BBPS
  PAYOUT
  QR
  UPI
  RECHARGE
  AEPS
  DMT
  TRAVEL
  OTHER
}

model ServiceRoute {
  id        String           @id @default(cuid())
  key       String           @unique // machine key, e.g. "payout_bulkpe"
  name      String // human label, e.g. "Payout (BulkPe)"
  type      ServiceRouteType @default(SERVICE)
  kind      ServiceRouteKind @default(OTHER)
  provider  String? // e.g. "BULKPE", "SAMEDAY", "EKYCHUB"
  enabled   Boolean          @default(true)
  note      String? // operational note shown in the On/Off panel
  balance   Decimal?         @db.Decimal(14, 2) // vendor wallet balance (dashboard)
  sortOrder Int              @default(0)
  meta      Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type, enabled])
  @@index([kind, enabled])
}

// ---------- Generic API idempotency ----------
// Guards non-ledger operations (e.g. "submit payout request") against
// duplicate submissions. Money-movement idempotency lives on WalletTxn.idempotencyKey.

model IdempotencyKey {
  id        String    @id @default(cuid())
  key       String    @unique
  scope     String // e.g. "payout.create"
  userId    String?
  status    String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED
  response  Json?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([scope, createdAt])
  @@index([expiresAt])
}

// ---------- DB-backed rate limiter ----------
// Fixed-window counters shared across all PM2 processes on the EC2 box
// (no Redis required to start). `key` encodes the bucket + window.

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "login:ip:1.2.3.4:1719500400"
  count       Int      @default(0)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

// =====================================================================
// Payouts (BulkPe) — bank/UPI disbursals with maker-checker + ledger holds
// =====================================================================

enum PayoutMode {
  IMPS
  NEFT
  RTGS
  UPI
}

enum PayoutStatus {
  DRAFT // created but not submitted (reserved for future bulk uploads)
  PENDING_APPROVAL // submitted by maker, funds held, awaiting checker
  APPROVED // checker approved, queued for the worker
  PROCESSING // sent to BulkPe, awaiting terminal state (webhook/poll)
  SUCCESS // settled at BulkPe; hold captured into a real DEBIT
  FAILED // BulkPe declined / failed; hold released back to spendable
  REJECTED // checker rejected before initiation; hold released
  REVERSED // settled then reversed by bank/BulkPe; funds returned
}

/// A single disbursal to a beneficiary. The user pays
/// totalDebit = amount + serviceCharge + GST(serviceCharge); the beneficiary
/// receives the full `amount`. Funds are reserved with a ledger hold at
/// submit and only converted to a real DEBIT (captureHold) on terminal
/// success — released on failure/rejection/reversal.
model PayoutRequest {
  id     String @id @default(cuid())
  // Wallet owner whose balance is held/debited (also the maker in our flow).
  userId String
  user   User   @relation("PayoutOwner", fields: [userId], references: [id])

  // Beneficiary — PII encrypted at rest (AES-256-GCM via fieldEncryption).
  beneficiaryName String
  accountNumber   String // ENCRYPTED (bank a/c number, or UPI VPA for mode=UPI)
  ifsc            String? // ENCRYPTED (null for UPI)
  accountLast4    String // plain, for safe display only

  mode PayoutMode

  // Money (charge is ON TOP — beneficiary gets `amount`, user pays `totalDebit`).
  amount        Decimal @db.Decimal(14, 2)
  serviceCharge Decimal @db.Decimal(14, 2)
  gst           Decimal @db.Decimal(14, 2) // 18% of serviceCharge
  totalDebit    Decimal @db.Decimal(14, 2) // amount + serviceCharge + gst

  status PayoutStatus @default(PENDING_APPROVAL)

  // Maker-checker
  makerId   String // who created the request (usually == userId)
  checkerId String? // who approved/rejected
  remarks   String? // checker remarks on approve/reject

  // Provider (BulkPe) correlation
  bulkpeReferenceId String  @unique // our idempotency reference_id sent to BulkPe
  bulkpeTxnId       String? // BulkPe's transaction id
  utr               String? // bank UTR on success
  failureReason     String?

  // Raw provider payloads for audit / reconciliation (never contains secrets).
  request  Json?
  response Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  approvedAt  DateTime?
  processedAt DateTime? // when handed to BulkPe
  completedAt DateTime? // terminal (success/failed/reversed)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([checkerId, status])
}

// =====================================================================
// POS machines (Same Day Solution) — local mirror + assignment layer.
//
// Machines themselves are sourced externally (read-only feed). This local
// model lets us OWN the assignment of a physical terminal to a platform
// user (retailer/distributor). `sync` upserts the external inventory by
// `externalId`; `assignedUserId` is set/cleared only by admins and never
// touched by the sync (assignment is our source of truth).
// =====================================================================

model PosMachine {
  id         String @id @default(cuid())
  externalId String @unique // Same Day machine id (stable external key)

  // Denormalized display fields copied from the external feed on each sync.
  mid      String? // merchant id
  tid      String? // terminal id
  serial   String? // device serial number
  model    String? // brand / machine_type label
  provider String  @default("SAMEDAY")
  status   String  @default("active") // active | inactive | maintenance | decommissioned
  location String?
  city     String?
  state    String?

  // Assignment (our source of truth — preserved across syncs).
  assignedUserId String?
  assignedUser   User?     @relation("PosAssignee", fields: [assignedUserId], references: [id])
  assignedAt     DateTime?
  assignedById   String? // admin who performed the last assignment

  // Full external payload for audit / future fields.
  meta Json?

  // Manual-inventory extensions (Console A5): machines may also be created
  // by hand / bulk CSV upload rather than the external sync.
  source    String  @default("SYNC") // SYNC | MANUAL
  brand     String? // device brand label (Pax, Verifone, ...) — free text
  company   String? // acquiring company / bank label
  condition String? // NEW | REFURBISHED | DAMAGED

  // Brand tenancy (teachway/lagoon/avika) that owns this machine's MDR pricing.
  brandId   String?
  brandRef  Brand?  @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  assignmentLogs PosAssignmentLog[]
  subscriptions  PosSubscription[]

  @@index([assignedUserId])
  @@index([status])
  @@index([tid])
  @@index([source])
  @@index([brandId])
}

model PosAssignmentLog {
  id        String     @id @default(cuid())
  machineId String
  machine   PosMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  action     String // assign | unassign
  fromUserId String? // previous assignee (if any)
  toUserId   String? // new assignee (null on unassign)
  byUserId   String // admin who performed the action
  note       String?
  createdAt  DateTime @default(now())

  // Tracking-report lifecycle (Console A5). An "assign" entry stays ACTIVE
  // until the machine moves again, at which point it is stamped RETURNED.
  status       String    @default("ACTIVE") // ACTIVE | RETURNED | EVENT (unassign rows)
  assignedDate DateTime? // effective assignment date (defaults to createdAt)
  // Dispatch milestones, editable by ops as the courier progresses.
  transitDate   DateTime?
  deliveredDate DateTime?
  returnedDate  DateTime?
  returnReason  String? // defective / merchant closed / upgrade / ...

  @@index([machineId, createdAt])
  @@index([status, createdAt])
  @@index([toUserId, action])
  @@index([returnedDate])
}

// =====================================================================
// Slides / Pop-up Management — homepage/dashboard banners & pop-ups.
//
// Admins manage colorful promotional SLIDE banners (carousel) and POPUP
// modals. The public surface only renders rows that are `active`, inside
// their [startAt, endAt] window, and targeted to the viewer's role
// (audienceRoles empty = everyone). Images live in Cloudinary (public
// delivery) — `imagePublicId` is destroyed when a slider is removed.
// =====================================================================

enum SliderKind {
  SLIDE // carousel banner on the dashboard
  POPUP // dismissible modal shown once per user (localStorage)
}

model Slider {
  id            String     @id @default(cuid())
  title         String
  imagePublicId String // Cloudinary public_id (for delivery + delete)
  imageUrl      String // secure_url
  linkUrl       String? // optional click-through target
  kind          SliderKind @default(SLIDE)
  // Target DB Role values (e.g. ["RETAILER","DISTRIBUTOR"]). Empty = all roles.
  audienceRoles String[]   @default([])
  active        Boolean    @default(true)
  sortOrder     Int        @default(0)
  startAt       DateTime? // null = live immediately
  endAt         DateTime? // null = no expiry
  createdById   String?
  createdBy     User?      @relation("SliderCreator", fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([kind, active])
}

// =====================================================================
// Static QR collections (third-party UPI QR, no webhook).
//
// Admin uploads ONE active StaticQr at a time; every retailer sees it and
// collects customer payments on it. Since the provider gives us no webhook,
// a retailer files a QrClaim (amount + 12-digit UPI UTR + screenshot) and
// an admin verifies the UTR in the provider's portal before the wallet is
// credited. Fraud posture:
//   - utr UNIQUE            → one UPI payment can be settled at most once,
//                             platform-wide, race-safe (DB-enforced).
//   - screenshotHash UNIQUE → the same image can't be re-submitted with
//                             different typed details.
//   - portalVerified        → per-admin attestation, audit-logged.
//   - amounts above a threshold need a SECOND, different admin (maker-checker).
//   - settlementBatchId/reconciledAt are phase-2 hooks: when the provider's
//     settlement file lands, every APPROVED claim must match a settled UTR;
//     unmatched ones get clawed back (CLAWED_BACK).
// =====================================================================

enum QrClaimStatus {
  PENDING // filed by retailer, awaiting admin review
  AWAITING_SECOND_APPROVAL // large amount: first admin approved, needs a different second admin
  APPROVED // credited to the retailer wallet
  REJECTED // refused by admin (note required)
  CLAWED_BACK // approved but provider settlement never matched — credit reversed
}

model StaticQr {
  id            String  @id @default(cuid())
  label         String // "ICICI counter QR — July 2026"
  upiVpa        String? // VPA encoded in the QR (shown to admins for eyeball checks)
  imagePublicId String // Cloudinary public_id
  imageUrl      String // secure_url (public delivery — the QR itself is not a secret)
  active        Boolean @default(true)

  createdById String
  createdBy   User   @relation("StaticQrCreator", fields: [createdById], references: [id])

  disabledAt   DateTime? // set when rotated out; claims dated after this are refused
  disabledById String?

  createdAt DateTime @default(now())

  claims QrClaim[]

  @@index([active])
}

// =====================================================================
// Admin Console expansion — Phases A1–A6 (functional parity with the
// reference platform's admin, built natively on the NextGen ledger).
// =====================================================================

// ---------- A1: Platform settings (typed key-value store) ----------
// Single-row-per-key JSON store for operational knobs an admin can change at
// runtime without a deploy: global wallet cap, wallet-ops approval threshold,
// T+1 settlement cron config, reversal rules, dashboard defaults, etc.
// Read through src/lib/settings.ts which owns defaults + zod validation.

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "wallet.global_cap", "settlement.t1"
  value       Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- A1: Admin wallet operations (push / pull) ----------
// Every admin-initiated credit (PUSH) or debit (PULL) of a user wallet. The
// money itself moves through the ledger (creditWallet/debitWallet) inside the
// same DB transaction that records this row; walletTxnId links the two.
// Amounts >= the configured approval threshold require a SECOND, different
// admin (maker-checker) before any money moves.

enum WalletOperationType {
  PUSH // admin credits the user wallet
  PULL // admin debits the user wallet
}

enum WalletOperationStatus {
  PENDING_APPROVAL // above threshold — awaiting a different admin
  COMPLETED // money moved, walletTxnId set
  REJECTED // checker refused; no money moved
  CANCELLED // maker withdrew before approval
}

model WalletOperation {
  id String @id @default(cuid())

  targetUserId String
  targetUser   User   @relation("WalletOpTarget", fields: [targetUserId], references: [id])

  actorId String // admin who initiated
  actor   User   @relation("WalletOpActor", fields: [actorId], references: [id])

  type       WalletOperationType
  walletType WalletType          @default(PRIMARY)
  amount     Decimal             @db.Decimal(14, 2)
  reasonCode String // FUND_LOAD | REFUND | CHARGEBACK | CORRECTION | PENALTY | PROMO | OTHER
  remarks    String // mandatory human explanation

  status WalletOperationStatus @default(COMPLETED)

  // Maker-checker for large amounts.
  approvedById String?
  approvedBy   User?     @relation("WalletOpApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectedNote String?

  // Ledger linkage — set when the movement lands.
  walletTxnId String? @unique

  ip        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetUserId, createdAt])
  @@index([actorId, createdAt])
  @@index([status, createdAt])
}

// ---------- A3: MDR scheme engine ----------
// MDR (merchant discount rate) pricing for acquiring-style rails (POS / PG /
// QR), separate from the service charge Scheme. A slab matches on service
// kind + payment mode + card network band and yields the platform MDR and the
// per-tier commission share. Exactly one scheme may be the default.

enum MdrServiceKind {
  POS
  PG
  QR
  UPI
}

model MdrScheme {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  isDefault   Boolean   @default(false)
  createdById String?

  // Hierarchical derivation (mirrors Scheme): ownerId = deriving network
  // parent (null = platform scheme); parentSchemeId = source scheme. Derived
  // MDR must be >= the parent's for each slab — the difference is the chain's
  // margin, split at transaction time.
  ownerId        String?
  parentSchemeId String?
  parentScheme   MdrScheme?  @relation("MdrSchemeDerivation", fields: [parentSchemeId], references: [id])
  derivedSchemes MdrScheme[] @relation("MdrSchemeDerivation")

  slabs       MdrSlab[]
  users       User[]    @relation("UserMdrScheme")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active])
  @@index([isDefault])
  @@index([ownerId])
  @@index([parentSchemeId])
}

model MdrSlab {
  id       String    @id @default(cuid())
  schemeId String
  scheme   MdrScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  serviceKind MdrServiceKind
  // Payment instrument dimension, e.g. "CARD_CREDIT", "CARD_DEBIT", "UPI",
  // "NETBANKING", "*" (any).
  paymentMode String         @default("*")
  // Card/acquirer dimensions (Same Day style). null = any. Resolution picks
  // the most specific matching slab (each exact dimension match scores over
  // a wildcard).
  company        String? // POS acquiring company label (PosMachine.company)
  cardType       String? // CREDIT | DEBIT | PREPAID
  brandType      String? // VISA | MASTERCARD | RUPAY | AMEX | ...
  classification String? // PLATINUM | GOLD | CLASSIC | BUSINESS | ...
  minAmount   Decimal        @db.Decimal(14, 2)
  maxAmount   Decimal        @db.Decimal(14, 2)

  // MDR charged to the merchant/user for this band. mdrValue is the T+1
  // (standard) rate; mdrValueT0 applies to instant (T+0) settlement and
  // falls back to mdrValue when zero/unset.
  mdrType    RateType @default(PERCENT)
  mdrValue   Decimal  @default(0) @db.Decimal(14, 4)
  mdrValueT0 Decimal  @default(0) @db.Decimal(14, 4)

  // Commission share distributed up the chain (same RateType semantics).
  commissionType             RateType @default(PERCENT)
  commissionRetailer         Decimal  @default(0) @db.Decimal(14, 4)
  commissionDistributor      Decimal  @default(0) @db.Decimal(14, 4)
  commissionMaster           Decimal  @default(0) @db.Decimal(14, 4)
  commissionSuperDistributor Decimal  @default(0) @db.Decimal(14, 4)

  // Cascade model: link back to the parent-scheme slab this one was derived
  // from (bands + types locked to the parent; only mdrValue changes).
  parentSlabId String?

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schemeId, serviceKind, active])
  @@index([parentSlabId])
}

// ---------- A3: Per-user limits & tiers ----------
// One row per user (absence = platform defaults from PlatformSetting).
// Enforced in the transaction orchestrator and settlement engine.

model UserLimit {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Wallet cap — max walletBalance this user may hold (null = platform cap).
  walletCap Decimal? @db.Decimal(14, 2)

  // Per-day transaction ceilings (null = risk-engine defaults apply).
  dailyTxnAmountCap Decimal? @db.Decimal(14, 2)
  dailyTxnCountCap  Int?

  // Settlement tier — daily settlement ceiling + per-transfer ceiling.
  settlementDailyCap   Decimal? @db.Decimal(14, 2)
  settlementPerTxnCap  Decimal? @db.Decimal(14, 2)
  settlementTier       String? // display label, e.g. "TIER_1", "GOLD"

  note        String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- A4: Reversal desk ----------
// A compensating money movement raised by an admin against a settled entity
// (transaction / settlement / AEPS txn / wallet entry). NEVER edits history —
// posts an opposite-direction ledger entry and links it here. Maker-checker
// above the configured threshold.

enum ReversalKind {
  TRANSACTION // service transaction (BBPS/recharge/DMT/...)
  SETTLEMENT
  AEPS
  WALLET_ENTRY // raw ledger correction
}

enum ReversalStatus {
  PENDING_APPROVAL
  COMPLETED
  REJECTED
  CANCELLED
}

model Reversal {
  id String @id @default(cuid())

  kind ReversalKind
  // What is being reversed — polymorphic reference + human ref for display.
  refType String // "Transaction" | "SettlementTransfer" | "WalletTxn" | ...
  refId   String
  refLabel String? // e.g. the TXN refId shown in the UI

  targetUserId String
  targetUser   User   @relation("ReversalTarget", fields: [targetUserId], references: [id])

  actorId String
  actor   User   @relation("ReversalActor", fields: [actorId], references: [id])

  // Direction of the compensation from the TARGET USER's perspective.
  direction  WalletDirection // CREDIT = money returned to user
  walletType WalletType      @default(PRIMARY)
  amount     Decimal         @db.Decimal(14, 2)
  reason     String // mandatory explanation

  status ReversalStatus @default(COMPLETED)

  approvedById String?
  approvedAt   DateTime?
  rejectedNote String?

  // Ledger linkage (idempotent — one compensating entry per reversal).
  walletTxnId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetUserId, createdAt])
  @@index([status, createdAt])
  @@index([refType, refId])
}

// ---------- A4: T+1 settlement engine ----------
// Per-user auto-settlement configuration + per-run records. The daily worker
// job walks eligible users, computes the sweepable AEPS-wallet balance, and
// moves it to the primary wallet (internal mode) — every run is idempotent
// per (user, IST day) via SettlementRun.dayKey.

model UserSettlementConfig {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  autoSettleEnabled Boolean   @default(true)
  pausedUntil       DateTime? // admin pause — null/past = active
  pausedReason      String?
  // Float kept in the AEPS wallet after a sweep (null = settle everything).
  keepBalance       Decimal?  @db.Decimal(14, 2)

  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum SettlementRunStatus {
  SUCCESS
  SKIPPED
  FAILED
}

model SettlementRun {
  id     String @id @default(cuid())
  userId String

  // IST day key (YYYY-MM-DD) — with userId forms the idempotency guard.
  dayKey  String
  trigger String @default("CRON") // CRON | MANUAL (admin run-now)

  amount Decimal             @default(0) @db.Decimal(14, 2)
  status SettlementRunStatus
  detail String? // skip/failure reason

  walletTxnDebitId  String? // AEPS wallet debit entry
  walletTxnCreditId String? // primary wallet credit entry

  ranById   String? // admin id when trigger = MANUAL
  createdAt DateTime @default(now())

  @@unique([userId, dayKey, trigger])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ---------- A4: Settlement alerts ----------
model SettlementAlert {
  id        String    @id @default(cuid())
  severity  String // INFO | WARNING | CRITICAL
  title     String
  detail    Json?
  userId    String? // affected user, when applicable
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([readAt, createdAt])
}

// ---------- A5: POS rental plans & subscriptions ----------
// A rental plan defines the recurring machine fee; a subscription binds a
// machine + user to a plan. The monthly billing job debits the user wallet
// (reason RENTAL) idempotently per (subscription, billing period).

model PosRentalPlan {
  id          String  @id @default(cuid())
  name        String
  description String?
  monthlyRent Decimal @db.Decimal(14, 2)
  // One-time charges captured at subscription start (0 = none).
  setupFee    Decimal @default(0) @db.Decimal(14, 2)
  deposit     Decimal @default(0) @db.Decimal(14, 2)
  // Default GST treatment for this plan. When true, subscriptions created from
  // this plan add 18% GST on top of the rent (and on the commission spread) by
  // default; the assigner can still override per subscription.
  includeGst  Boolean @default(false)
  active      Boolean @default(true)

  // Owner of this plan. null = platform plan (created by admin, visible to
  // everyone). A non-null ownerId means a network user (SD/MD/Distributor)
  // created this plan privately; only that user (and admins) can see/use it.
  ownerId String?
  owner   User?   @relation("PosRentalPlanOwner", fields: [ownerId], references: [id])

  subscriptions PosSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Plan names are unique per owner (platform plans share the null-owner scope).
  @@unique([ownerId, name])
}

// ---------- A5b: POS rental subscription (enhanced for multi-tier) ----------
// Each tier in the hierarchy can set its own monthly rent + commission when
// assigning a machine downstream. The billing engine debits the subscriber,
// credits commissions to every ancestor in the chain, and optionally adds
// 18% GST on the rental amount.

enum PosSubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model PosSubscription {
  id String @id @default(cuid())

  machineId String
  machine   PosMachine @relation(fields: [machineId], references: [id])

  userId String
  user   User   @relation("PosSubscriber", fields: [userId], references: [id])

  planId String
  plan   PosRentalPlan @relation(fields: [planId], references: [id])

  status     PosSubscriptionStatus @default(ACTIVE)
  billingDay Int                   @default(1) // day-of-month the rent is due

  // Per-subscription rental override. When set, this amount is billed instead
  // of the plan's monthlyRent — lets each tier set its own downstream rent.
  monthlyRent Decimal? @db.Decimal(14, 2)

  // GST toggle: when true, 18% GST is added on top of the monthly rent.
  includeGst Boolean @default(false)

  // Commission the ASSIGNER (creator of this subscription) earns each month.
  // This is the difference between what the subscriber pays and what the
  // assigner's own upstream rent is. Stored explicitly for transparency.
  commission Decimal @default(0) @db.Decimal(14, 2)

  // Who created this subscription (the assigner — parent in the hierarchy).
  createdById String?

  startedAt   DateTime  @default(now())
  cancelledAt DateTime?

  invoices PosRentalInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([machineId])
  @@index([status, billingDay])
}

enum PosInvoiceStatus {
  PAID
  FAILED // insufficient wallet balance — retried next run
  WAIVED
}

model PosRentalInvoice {
  id             String          @id @default(cuid())
  subscriptionId String
  subscription   PosSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Billing period key (YYYY-MM) — idempotency guard per subscription+month.
  periodKey String
  amount    Decimal          @db.Decimal(14, 2) // base rent charged
  gstAmount Decimal          @default(0) @db.Decimal(14, 2) // 18% GST (when includeGst)
  totalAmount Decimal        @default(0) @db.Decimal(14, 2) // amount + gstAmount (total debited)
  commissionAmount Decimal   @default(0) @db.Decimal(14, 2) // commission credited to assigner
  status    PosInvoiceStatus
  detail    String?

  walletTxnId String? @unique
  // Wallet txn for the commission credit to the assigner.
  commissionTxnId String? @unique

  createdAt DateTime @default(now())

  @@unique([subscriptionId, periodKey])
  @@index([status, createdAt])
}

// ---------- A6: AEPS control centre ----------
// Local AEPS merchant registry + settlement accounts + settlement records.
// Provider-agnostic: rows carry the provider name + provider merchant id so
// they survive a rail switch (Paysprint → anything).

enum AepsMerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

model AepsMerchant {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider           String // PAYSPRINT | MOCK | ...
  providerMerchantId String?
  status             AepsMerchantStatus @default(PENDING)

  // Onboarding metadata (BC agent id, device serial, etc.)
  meta Json?

  activatedAt DateTime?
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

enum AepsAccountStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model AepsSettlementAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("AepsAccountOwner", fields: [userId], references: [id], onDelete: Cascade)

  accountHolderName String
  accountNumber     String // ENCRYPTED at rest (fieldEncryption)
  accountLast4      String // plain, display only
  ifsc              String
  bankName          String?

  status       AepsAccountStatus @default(PENDING_APPROVAL)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  pennyDropVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

enum AepsSettlementStatus {
  PROCESSING
  SUCCESS
  FAILED
}

/// A settlement of AEPS-wallet funds out to a bank account (or into the
/// primary wallet when accountId is null). Wallet legs go through the ledger.
model AepsSettlement {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("AepsSettlementOwner", fields: [userId], references: [id])

  accountId String? // AepsSettlementAccount.id — null = internal move to primary
  amount    Decimal @db.Decimal(14, 2)
  charge    Decimal @default(0) @db.Decimal(14, 2)
  mode      String  @default("INTERNAL") // INTERNAL | IMPS | NEFT

  status AepsSettlementStatus @default(PROCESSING)
  utr    String?
  detail String?

  walletTxnDebitId  String? // AEPS wallet debit
  walletTxnCreditId String? // primary wallet credit (internal mode)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model QrClaim {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("QrClaimOwner", fields: [userId], references: [id])

  qrId String
  qr   StaticQr @relation(fields: [qrId], references: [id])

  amount Decimal  @db.Decimal(14, 2)
  // UPI UTR / RRN — 12 digits, visible in every UPI app. THE dedupe key.
  utr    String   @unique
  paidAt DateTime // when the customer paid (per the retailer)

  // Screenshot proof — stored privately in Cloudinary; admins view via signed
  // URLs. The sha256 of the uploaded bytes blocks image re-use across claims.
  screenshotPublicId String
  screenshotFormat   String?
  screenshotHash     String  @unique

  status QrClaimStatus @default(PENDING)

  // Maker-checker: for amounts above the threshold the FIRST approval only
  // stages the claim; a DIFFERENT admin must confirm before money moves.
  firstApprovedById String?
  firstApprovedAt   DateTime?

  reviewedById String?
  reviewedBy   User?     @relation("QrClaimReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?
  // Admin attestation that the UTR was found in the provider's merchant portal.
  portalVerified Boolean @default(false)

  // Phase-2 reconciliation hooks (provider settlement file matching).
  settlementBatchId String?
  reconciledAt      DateTime?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([reconciledAt])
}

// ---------- Multi-tier commission credits ----------
// One row per tier per successful transaction — powers the earnings ledger,
// commission certificates, and the "My Earnings" dashboards.

model CommissionCredit {
  id            String   @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  userId        String   // who received the commission
  user          User     @relation("CommissionCredits", fields: [userId], references: [id])
  tier          String   // RETAILER | DISTRIBUTOR | MASTER | SUPER
  amount        Decimal  @db.Decimal(14, 2) // NET credited to the wallet (gross - TDS)
  // TDS breakdown (Section 194H style): amount = grossAmount - tdsAmount.
  // grossAmount is nullable for legacy rows written before TDS was applied.
  grossAmount   Decimal? @db.Decimal(14, 2)
  tdsAmount     Decimal  @default(0) @db.Decimal(14, 2)
  walletTxnId   String?  // ref to the WalletTxn credit
  schemeId      String?  // which scheme resolved the split
  service       ServiceCode
  txnAmount     Decimal  @db.Decimal(14, 2) // original transaction amount
  createdAt     DateTime @default(now())

  @@index([transactionId])
  @@index([userId, createdAt])
  @@index([userId, service, createdAt])
}

// ---------- POS acquirer settlement ----------
// Tracks POS transaction proceeds — credited instantly (on webhook) or via
// T+1 cron depending on the user's instantSettlement flag.

model PosSettlementEntry {
  id             String   @id @default(cuid())
  transactionRef String   @unique // partner txn ID (idempotency key)
  machineId      String?  // local PosMachine id
  userId         String   // retailer who owns the machine
  user           User     @relation("PosSettlements", fields: [userId], references: [id])
  grossAmount    Decimal  @db.Decimal(14, 2) // full transaction amount
  mdrAmount      Decimal  @db.Decimal(14, 2) // MDR deducted
  netAmount      Decimal  @db.Decimal(14, 2) // credited to retailer
  mode           String   // INSTANT | T1
  status         String   @default("PENDING") // PENDING | SETTLED | FAILED
  settledAt      DateTime?
  walletTxnId    String?  // ref to the credit WalletTxn
  paymentMode    String?  // CARD | UPI | NFC | BHARATQR

  // Brand / provider pricing context (for per-brand MDR). The T+1 sweep
  // re-verifies MDR against the brand rate before crediting, so these record
  // the dimensions the capture was priced against.
  brandId   String? // Brand this capture belongs to (null = legacy/user-scheme priced)
  brand     Brand?  @relation(fields: [brandId], references: [id])
  provider  String? // acquiring/service provider (RAZORPAY | PAYTM | PINELAB | ...)
  mdrRateId String? // BrandMdrRate the MDR was resolved from (audit)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([brandId])
}

// ---------- Brand-scoped MDR & settlement ----------
// A Brand (e.g. teachway, lagoon, avika) groups POS machines under a common
// acquiring identity. Each brand carries its own MDR rate card (BrandMdrRate,
// keyed by provider + payment mode + amount band) and a default settlement
// mode. Every POS settlement resolves and deducts MDR against the brand's
// current rate before crediting the retailer wallet.

model Brand {
  id             String  @id @default(cuid())
  key            String  @unique // stable slug: teachway | lagoon | avika
  name           String
  description    String?
  active         Boolean @default(true)
  // Default settlement mode for this brand's captures. A per-user
  // instantSettlement override still forces INSTANT for that user.
  settlementMode String  @default("T1") // INSTANT | T1
  createdById    String?

  rates       BrandMdrRate[]
  machines    PosMachine[]
  settlements PosSettlementEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model BrandMdrRate {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Dimensions. "*" (or null) = wildcard; an exact match beats a wildcard.
  provider    String @default("*") // RAZORPAY | PAYTM | PINELAB | *
  paymentMode String @default("*") // CARD | UPI | NFC | BHARATQR | *

  minAmount Decimal @db.Decimal(14, 2)
  maxAmount Decimal @db.Decimal(14, 2)

  // MDR charged for this band. mdrValue is the T+1 (standard) rate; mdrValueT0
  // applies to instant (T+0) settlement and falls back to mdrValue when unset.
  mdrType    RateType @default(PERCENT)
  mdrValue   Decimal  @default(0) @db.Decimal(14, 4)
  mdrValueT0 Decimal  @default(0) @db.Decimal(14, 4)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, provider, active])
}

// ---------- Network wallet transfer ----------
// Direct parent→child wallet push/pull (not fund-request based).

model NetworkWalletTransfer {
  id        String   @id @default(cuid())
  fromId    String   // parent user
  from      User     @relation("NetworkTransfersOut", fields: [fromId], references: [id])
  toId      String   // child user
  to        User     @relation("NetworkTransfersIn", fields: [toId], references: [id])
  direction String   // PUSH | PULL
  amount    Decimal  @db.Decimal(14, 2)
  note      String?
  createdAt DateTime @default(now())

  @@index([fromId, createdAt])
  @@index([toId, createdAt])
}
