// =====================================================================
// JMP NextGenPay — production schema (Supabase Postgres + Prisma)
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth & RBAC ----------

enum Role {
  RETAILER
  DISTRIBUTOR
  MASTER_DISTRIBUTOR
  ADMIN
  SUPPORT
}

enum UserStatus {
  PENDING_KYC
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  phone           String     @unique
  passwordHash    String
  role            Role       @default(RETAILER)
  status          UserStatus @default(PENDING_KYC)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  twoFactorEnabled Boolean   @default(false)

  // hierarchy
  parentId        String?
  parent          User?      @relation("Hierarchy", fields: [parentId], references: [id])
  children        User[]     @relation("Hierarchy")

  // org / shop info
  shopName        String?
  shopAddress     String?
  pincode         String?
  state           String?
  city            String?

  // financial summary (denormalized for fast reads; keep authoritative ledger in WalletTxn)
  walletBalance   Decimal    @default(0) @db.Decimal(14, 2)

  kyc             Kyc?
  documents       Document[]
  wallet          WalletTxn[]
  transactions    Transaction[]
  fundRequestsRaised   FundRequest[] @relation("FundRequester")
  fundRequestsApproved FundRequest[] @relation("FundApprover")
  apiKeys         ApiKey[]
  sessions        Session[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  commissionSlabs CommissionSlab[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  @@index([role])
  @@index([parentId])
  @@index([status])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  device       String?
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Otp {
  id        String   @id @default(cuid())
  channel   String   // SMS | EMAIL
  target    String   // phone or email
  codeHash  String
  purpose   String   // LOGIN | REGISTER | RESET | TXN
  attempts  Int      @default(0)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([target, purpose])
}

// ---------- KYC & documents ----------

enum KycStatus {
  NOT_STARTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model Kyc {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          KycStatus @default(NOT_STARTED)
  panNumber       String?
  panVerifiedAt   DateTime?
  aadhaarLast4    String?
  aadhaarVerifiedAt DateTime?
  gstin           String?
  dob             DateTime?
  rejectedReason  String?
  reviewedById    String?
  reviewedAt      DateTime?
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum DocumentType {
  PAN
  AADHAAR_FRONT
  AADHAAR_BACK
  SHOP_PHOTO
  BANK_PROOF
  GST_CERT
  SELFIE
  AGREEMENT
  OTHER
}

model Document {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         DocumentType
  // Cloudinary
  publicId     String       // e.g. "nextgenpay/kyc/abc123"
  url          String       // secure_url
  resourceType String       @default("image") // image | raw | video
  format       String?
  bytes        Int?
  width        Int?
  height       Int?
  // privacy: signed delivery — never expose publicly
  isSensitive  Boolean      @default(true)
  uploadedAt   DateTime     @default(now())

  @@index([userId, type])
}

// ---------- Wallet ledger (double-entry-style) ----------

enum WalletDirection {
  CREDIT
  DEBIT
}

enum WalletReason {
  TOPUP
  WITHDRAW
  TRANSACTION
  COMMISSION
  REVERSAL
  ADJUSTMENT
  FUND_TRANSFER_IN
  FUND_TRANSFER_OUT
  FEE
  PENALTY
}

model WalletTxn {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  direction     WalletDirection
  reason        WalletReason
  amount        Decimal         @db.Decimal(14, 2)
  balanceAfter  Decimal         @db.Decimal(14, 2)
  refType       String?         // "Transaction" | "FundRequest" | etc
  refId         String?
  note          String?
  createdAt     DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([refType, refId])
}

// ---------- Transactions ----------

enum ServiceCode {
  AEPS_BALANCE
  AEPS_WITHDRAW
  AEPS_MINI_STMT
  DMT_IMPS
  DMT_NEFT
  DMT_RTGS
  UPI_COLLECT
  UPI_PAYOUT
  WALLET_TOPUP
  WALLET_WITHDRAW
  RECHARGE_MOBILE
  RECHARGE_DTH
  RECHARGE_BROADBAND
  BILL_ELECTRICITY
  BILL_WATER
  BILL_GAS
  BILL_CREDIT_CARD
  BILL_EDUCATION
  BILL_INSURANCE
  TRAVEL_FLIGHT
  TRAVEL_HOTEL
  TRAVEL_BUS
  TRAVEL_TRAIN
  PAN_CARD
  INSURANCE
}

enum TxnStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  HOLD
}

model Transaction {
  id              String      @id @default(cuid())
  refId           String      @unique // human-friendly: TXN8K2X9P
  userId          String      // retailer who originated it
  user            User        @relation(fields: [userId], references: [id])
  service         ServiceCode
  amount          Decimal     @db.Decimal(14, 2)
  fee             Decimal     @default(0) @db.Decimal(14, 2)
  commission      Decimal     @default(0) @db.Decimal(14, 2)
  gst             Decimal     @default(0) @db.Decimal(14, 2)
  status          TxnStatus   @default(INITIATED)
  customer        String?     // mobile / consumerNo / VPA / a/c last 4
  operator        String?     // SBI, Jio, BSES, etc.
  // partner details
  partner         String?     // PAYSPRINT, RAZORPAY, etc.
  partnerTxnId    String?
  // arbitrary partner payload for audit / reconciliation
  request         Json?
  response        Json?
  errorCode       String?
  errorMessage    String?
  // refunds
  refundedAt      DateTime?
  refundRefId     String?

  ipAddress       String?
  device          String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([service, status])
  @@index([status, createdAt])
}

// ---------- Commissions ----------

model CommissionSlab {
  id          String      @id @default(cuid())
  userId      String      // applies to this user / level
  user        User        @relation(fields: [userId], references: [id])
  service     ServiceCode
  minAmount   Decimal     @db.Decimal(14, 2)
  maxAmount   Decimal     @db.Decimal(14, 2)
  // either flat or percent — but enforce one in app code
  flat        Decimal?    @db.Decimal(14, 2)
  percent     Decimal?    @db.Decimal(6, 4) // e.g. 0.0050 for 0.5%
  active      Boolean     @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  @@index([userId, service, active])
}

// ---------- Fund requests ----------

enum FundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model FundRequest {
  id            String            @id @default(cuid())
  requesterId   String
  requester     User              @relation("FundRequester", fields: [requesterId], references: [id])
  approverId    String?
  approver      User?             @relation("FundApprover", fields: [approverId], references: [id])
  amount        Decimal           @db.Decimal(14, 2)
  mode          String            // UTR | UPI | CASH
  utr           String?
  bankName      String?
  proofDocId    String?           // Document.id
  status        FundRequestStatus @default(PENDING)
  remarks       String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime          @default(now())

  @@index([requesterId, status])
  @@index([approverId, status])
}

// ---------- API keys (for white-label master distributors) ----------

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  keyId       String   @unique // public id
  secretHash  String
  scopes      String[] // ["txn.read","txn.create","wallet.topup"]
  ipAllowlist String[] @default([])
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ---------- Audit / system ----------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // user.login, kyc.approve, txn.refund, ...
  entity    String?  // User | Transaction | Kyc
  entityId  String?
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  channel   String   // INAPP | EMAIL | SMS | PUSH
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

// ---------- Master data ----------

model Operator {
  id        String      @id @default(cuid())
  service   ServiceCode
  name      String
  code      String      @unique
  logoUrl   String?
  active    Boolean     @default(true)
  meta      Json?

  @@index([service, active])
}

model Biller {
  id          String   @id @default(cuid())
  category    String   // ELECTRICITY | WATER | GAS | INSURANCE | EDUCATION
  name        String
  code        String   @unique
  state       String?
  active      Boolean  @default(true)
  partner     String?  // BBPS / BillAvenue
  partnerCode String?

  @@index([category, state, active])
}
